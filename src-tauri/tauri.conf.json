{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SeaCat Backtest",
  "version": "1.2.47",
  "identifier": "com.seacat.backtest",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:2111",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      { "title": "SeaCat Backtest", "width": 1440, "height": 980, "resizable": true }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  }
}